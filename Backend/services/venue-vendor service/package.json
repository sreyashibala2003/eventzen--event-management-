{
  "name": "eventzen-venue-vendor-service",
  "version": "1.0.0",
  "description": "EventZen Venue & Vendor Management Microservice",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "seed": "node src/utils/seedData.js",
    "cleanup:remove-location": "node src/utils/removeLocationFields.js",
    "migrate:status-availability": "node src/utils/migrateStatusesToAvailability.js"
  },
  "keywords": ["eventzen", "venue", "vendor", "microservice", "nodejs", "express", "mongodb"],
  "author": "EventZen Engineering Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.1.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "moment": "^2.30.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-mongodb": "^5.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "@jest/globals": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/utils/seedData.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
