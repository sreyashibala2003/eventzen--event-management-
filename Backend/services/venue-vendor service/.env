# EventZen Venue & Vendor Service Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/eventzen_venues
MONGODB_TEST_URI=mongodb://localhost:27017/eventzen_venues_test

# JWT Configuration - RSA Keys (must match auth service)
JWT_PUBLIC_
JWT_EXPIRE_TIME=24h
# Skip JWT signature verification for testing (development only)
JWT_SKIP_VERIFICATION=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_ADMIN_MAX_REQUESTS=5000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API Gateway Configuration
API_GATEWAY_URL=http://localhost:8080

# Logging
LOG_LEVEL=info
ENABLE_MONGODB_LOGGING=false

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# External Services
EVENT_SERVICE_URL=http://localhost:3002
AUTH_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004