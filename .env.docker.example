# Published ports
FRONTEND_PORT=5173
AUTH_SERVICE_PORT=8081
VENUE_VENDOR_SERVICE_PORT=3001
EVENT_SERVICE_PORT=3002
BOOKING_SERVICE_PORT=5050

# Frontend build-time URLs
VITE_API_BASE_URL=http://localhost:8081/api/v1
VITE_EVENT_SERVICE_URL=http://localhost:3002/api/v1
VITE_VENUE_VENDOR_SERVICE_URL=http://localhost:3001/api/v1
VITE_BOOKING_SERVICE_URL=http://localhost:5050/api/v1

# Shared frontend origin
ALLOWED_ORIGINS=http://localhost:5173

# MongoDB URIs
VENUE_VENDOR_MONGODB_URI=mongodb://mongo:27017/eventzen_venues
EVENT_MONGODB_URI=mongodb://mongo:27017/eventzen_events
BOOKING_MONGODB_URI=mongodb://mongo:27017/eventzen_bookings
BOOKING_DATABASE_NAME=eventzen_bookings

# Auth service database
DB_URL=jdbc:mysql://mysql:3306/eventzen_auth?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=eventzen
DB_PASSWORD=eventzen

# Local-dev JWT mode
JWT_SKIP_VERIFICATION=true
DUMMY_RAZORPAY_KEY=rzp_test_eventzen_dummy

# Optional JWT keys for production-like verification.
# In this compose setup the auth service can auto-generate keys and
# the other services run with JWT_SKIP_VERIFICATION=true for local use.
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
